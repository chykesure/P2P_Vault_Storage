{
  "expo": {
    "name": "P2P Storage Vault",
    "slug": "p2p-storage-vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C5CE7"
    },
    "scheme": "p2pstoragevault",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.p2pstoragevault.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs camera access to upload photos to your encrypted vault.",
        "NSPhotoLibraryUsageDescription": "This app needs photo library access to upload photos to your encrypted vault."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#6C5CE7"
      },
      "package": "com.p2pstoragevault.app",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "p2pstoragevault"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "walletConnectProjectId": "88caf1f4db83db8797f12037fbd9f9e1",
      "contractAddress": "0x0000000000000000000000000000000000000000",
      "pinataJwt": "",
      "network": "polygonAmoy",
      "eas": {
        "projectId": "your_eas_project_id"
      }
    }
  }
}