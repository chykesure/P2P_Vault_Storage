# ============================================
# P2P Storage Vault — Expo Environment Config
# ============================================
#
# In Expo, you have TWO ways to set these values:
#
# Option 1: EXPO_PUBLIC_* environment variables (set in .env or CI/CD)
#   - Accessible at runtime via process.env.EXPO_PUBLIC_*
#   - Requires: npx expo start --clear (or rebuild dev client)
#
# Option 2: app.json → extra field (recommended for static values)
#   - Edit app.json and update the "extra" object
#   - Access via: Constants.expoConfig.extra.*
#   - No rebuild needed for Expo Go
#
# The app checks BOTH sources (env vars take priority).

# WalletConnect Project ID — Get from https://cloud.walletconnect.com
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Deployed FileVault contract address on Sepolia testnet
EXPO_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Pinata JWT token — Get from https://www.pinata.cloud (API Keys → JWT)
EXPO_PUBLIC_PINATA_JWT=your_pinata_jwt

# Optional: Pinata API credentials
EXPO_PUBLIC_PINATA_API_KEY=
EXPO_PUBLIC_PINATA_SECRET_KEY=

# Network: sepolia (testnet) | polygon | mainnet
EXPO_PUBLIC_NETWORK=sepolia
